{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "git": {
    "deploymentEnabled": true
  },
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.redi.healthcare" }],
      "destination": "https://redi.healthcare/:path*",
      "permanent": true
    }
  ]
}
