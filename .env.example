# =====================================================================
# Redi Health — environment contract
# Copy to `.env.local` for development, or paste into Vercel → Settings →
# Environment Variables for Preview / Production. `scripts/check-env.mjs`
# refuses to build production when production-required vars are missing
# (toggle with SASTIPE_STRICT_ENV=1).
# =====================================================================

# ---------- App identity ---------------------------------------------
NEXT_PUBLIC_APP_NAME="Redi Health"
NEXT_PUBLIC_APP_URL="https://redi.healthcare"
NEXT_PUBLIC_DEFAULT_LOCALE="en"
NEXT_PUBLIC_SUPPORTED_LOCALES="en,sq,rom,ro,hu,sk,cs,bg,sr,hr,bs,mk,sl,el,tr"

# ---------- Database (Supabase / Neon / Postgres) --------------------
DATABASE_URL="postgres://user:pass@host:5432/redi_health?sslmode=require"

# ---------- Supabase (auth, optional) --------------------------------
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# ---------- AI providers --------------------------------------------
# At least one of these must be set in production for /api/chat etc.
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
AI_DAILY_BUDGET_EUR="50"
AI_USER_DAILY_CAP="40"

# ---------- Rate limiting (Upstash Redis, multi-instance safe) -------
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ---------- Observability --------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
LANGFUSE_PUBLIC_KEY=""
LANGFUSE_SECRET_KEY=""
LANGFUSE_BASE_URL=""
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://eu.i.posthog.com"

# ---------- Outbound email (Resend) ----------------------------------
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Redi Health <no-reply@redi.healthcare>"

# ---------- Capacitor mobile shells ----------------------------------
# Override at build time only when targeting staging / preview hosts.
CAP_SERVER_URL="https://redi.healthcare"
